# See docs/ENVIRONMENTS.md for local, preview, and production value rules.
# Core
# DATABASE_URL must be a Postgres connection string. SUPABASE_URL is only the Supabase API endpoint.
DATABASE_URL=postgres://user:password@localhost:5432/silver_salt
# Optional alias accepted by the app when Vercel or a database integration creates it.
# POSTGRES_URL=postgres://user:password@localhost:5432/silver_salt
APP_BASE_URL=http://localhost:3000
CRON_SECRET=replace-me

# Clerk
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SILVER_SALT_STRIPE_PRICE_ID=price_...

# Email
RESEND_API_KEY=re_...
EMAIL_FROM=Silver & Salt Capital <hello@silverandsaltcapital.com>
OWNER_EMAIL=tori@silverandsaltcapital.com

# Group defaults
SILVER_SALT_CALENDAR_URL=https://calendar.google.com/calendar/appointments/schedules/AcZssZ1_9O59IJaGAZWnM6duwcPuqluoIu3ui_NMCu5iRHiJT_CRC9xjcoKWwMSG_9Zaxz1kQAMRU4A0?gv=true

# Local-only test helper. Do not enable in production.
ALLOW_TEST_AUTH_HEADER=0
ENABLE_MOCK_SIGNUP=0
LOCAL_TEST_AUTH_EMAIL=tori@silverandsaltcapital.com
